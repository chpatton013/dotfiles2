#!/bin/bash --norc
# Detect the controlling terminal's light/dark background by querying it with
# OSC 11, and cache the result ("light" or "dark") in an observable state file.
#
# OSC 11 is a terminal round-trip, so this works locally, over SSH, and through
# tmux (with `allow-passthrough`) -- including on headless machines whose
# appearance lives on a remote controlling terminal.
#
# Run this once at interactive shell startup (and on manual refresh), NOT on
# every application invocation: repeated in-band queries add latency and can
# leak their replies into the shell as stray input.
set -uo pipefail

# A single global file assumes one active appearance at a time (true for a
# single laptop). Key this by tty/session if that assumption ever breaks.
state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/color-theme"
state_file="$state_dir/name"
default="${COLOR_THEME_DEFAULT:-dark}"

# Print the best value we can without querying: last known, else default.
function fallback() {
  if [ -r "$state_file" ]; then
    cat "$state_file"
  else
    echo "$default"
  fi
}

# Query OSC 11 against the controlling terminal and echo the raw reply. Reads
# and writes /dev/tty directly because this script is typically run inside a
# command substitution, where stdout is a pipe rather than the terminal.
function query_osc11() {
  local saved response
  saved="$(stty -g </dev/tty 2>/dev/null)" || return 1
  # Raw mode with echo off so the reply is not printed or line-buffered.
  stty raw -echo </dev/tty 2>/dev/null || return 1
  printf '\e]11;?\a' >/dev/tty
  # Read only up to the reply's BEL terminator, not until the timeout. The reply
  # is `\e]11;rgb:.../.../...\a` (we queried with a BEL terminator, so the reply
  # mirrors it). Using `read -d ''` here would drain the whole tty input queue
  # for the full timeout, swallowing any characters the user typed ahead during
  # the slow shell startup. Stopping at the terminator leaves later keystrokes
  # in the buffer.
  IFS= read -r -d $'\a' -t 1 response </dev/tty || true
  stty "$saved" </dev/tty 2>/dev/null
  printf '%s' "$response"
}

# Decide light/dark from an OSC 11 reply of the form
# `\e]11;rgb:RRRR/GGGG/BBBB\e\\` (components may be 1-4 hex digits).
function classify() {
  local reply="$1" r g b lum
  if [[ ! "$reply" =~ rgb:([0-9a-fA-F]+)/([0-9a-fA-F]+)/([0-9a-fA-F]+) ]]; then
    return 1
  fi
  # Use the high byte of each component (first two hex digits, padded).
  r=$((16#$(printf '%s' "${BASH_REMATCH[1]}0" | cut -c1-2)))
  g=$((16#$(printf '%s' "${BASH_REMATCH[2]}0" | cut -c1-2)))
  b=$((16#$(printf '%s' "${BASH_REMATCH[3]}0" | cut -c1-2)))
  # Perceptual luminance on a 0-255 scale; midpoint splits light from dark.
  lum=$(( (r * 299 + g * 587 + b * 114) / 1000 ))
  if [ "$lum" -lt 128 ]; then
    echo dark
  else
    echo light
  fi
}

function main() {
  local reply name

  # Need a controlling terminal to query.
  if [ ! -e /dev/tty ] || { [ ! -t 0 ] && [ ! -t 1 ]; }; then
    fallback
    return 0
  fi

  reply="$(query_osc11)" || { fallback; return 0; }
  name="$(classify "$reply")" || { fallback; return 0; }

  mkdir -p "$state_dir"
  printf '%s\n' "$name" >"$state_file"
  echo "$name"
}

main "$@"
